# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript/JavaScript files
[*.{ts,tsx,js,jsx}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# JSON files
[*.json]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true

# CSS files
[*.{css,scss}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2

# HTML files
[*.html]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2

# PowerShell scripts
[*.ps1]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 2

# Batch files
[*.{bat,cmd}]
charset = utf-8
end_of_line = crlf

# Config files
[*.{conf,config}]
charset = utf-8
end_of_line = lf
