{
  "name": "drserv-website",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cf": "npm run build && node scripts/check-wrangler-platform.mjs && wrangler dev",
    "dev:api": "node scripts/check-wrangler-platform.mjs && wrangler dev --port 3001",
    "dev:all": "npm run build && node scripts/check-wrangler-platform.mjs && concurrently -n api,web \"wrangler dev --port 3001\" \"npm run dev\"",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "d1:migrate": "wrangler d1 execute myd1_db --remote --file=migrations/0001_create_inquiries.sql",
    "d1:migrate:local": "wrangler d1 execute myd1_db --local --file=migrations/0001_create_inquiries.sql",
    "d1:latest": "wrangler d1 execute myd1_db --remote --command=\"SELECT id, organization, contact_name, email, inquiry_type, created_at FROM inquiries ORDER BY id DESC LIMIT 5;\"",
    "test:email": "curl -s -X POST https://www.drserv.com.tw/api/inquiry -H \"Content-Type: application/json\" -d \"{\\\"organization\\\":\\\"npm測試\\\",\\\"contactName\\\":\\\"測試\\\",\\\"phone\\\":\\\"0912345678\\\",\\\"email\\\":\\\"test@example.com\\\",\\\"inquiryType\\\":\\\"其他\\\",\\\"message\\\":\\\"npm run test:email 自動測試，請忽略。\\\"}\"",
    "start": "vite"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.49.2",
    "react-router-dom": "^7.13.1",
    "react-scroll": "^1.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-scroll": "^1.8.10",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.1.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wrangler": "^4.0.0"
  }
}
