# API 伺服器埠號（可選，預設 3001）
# PORT=3001

# 資料庫檔案路徑（可選，預設為 server/data/inquiries.db）
# DB_PATH=/path/to/inquiries.db

# SMTP 寄信設定（必填才會寄信到 service@drserv.com.tw）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yjhwang59@gmail.com
SMTP_PASS=your-smtp-password
# 寄件者顯示（可選，預設同 SMTP_USER）
SMTP_FROM=service@drserv.com.tw
